        <activity
            android:name=".ui.homeScreen.HomeActivity"
            android:exported="false"
            android:label="@string/title_activity_home" />
        <activity
            android:name=".ui.startScreen.StartActivity"
            android:exported="false"
            android:label="@string/title_activity_start" />
