<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.ZooMatch" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryContainer">@color/purple_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/purple_dark</item>
        <item name="colorSecondary">@color/purple_medium</item>
        <item name="android:statusBarColor">@color/purple_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.ZooMatch" parent="Base.Theme.ZooMatch" />

    <style name="FullScreenDialog" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
