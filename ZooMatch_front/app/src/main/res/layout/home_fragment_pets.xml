<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:paddingTop="20dp"
  android:paddingBottom="20dp">


  <com.google.android.material.search.SearchBar
    android:id="@+id/searchBar"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="40dp"
    android:layout_marginTop="20dp"
    android:hint="Find by name"
    app:layout_constraintEnd_toStartOf="@+id/viewChangeButton"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />


  <com.google.android.material.button.MaterialButton
    android:id="@+id/viewChangeButton"
    style="@style/Widget.Material3.Button.IconButton"
    android:layout_width="wrap_content"
    android:layout_height="48dp"
    android:layout_marginEnd="4dp"
    android:contentDescription="viewChange"
    app:icon="@drawable/test_avatar"
    app:layout_constraintBottom_toBottomOf="@id/searchBar"
    app:layout_constraintEnd_toStartOf="@+id/filterButton"
    app:layout_constraintTop_toTopOf="@+id/searchBar" />


  <com.google.android.material.button.MaterialButton
    android:id="@+id/filterButton"
    style="@style/Widget.Material3.Button.IconButton"
    android:layout_width="48dp"
    android:layout_height="48dp"
    android:layout_marginEnd="40dp"
    android:contentDescription="filter"
    app:icon="@drawable/test_avatar"
    app:layout_constraintBottom_toBottomOf="@+id/viewChangeButton"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="@+id/viewChangeButton" />

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/petsRecyclerView"
    android:layout_width="0dp"
    android:layout_height="0dp"
    app:layout_constraintTop_toBottomOf="@id/searchBar"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:paddingHorizontal="40dp"
    android:clipToPadding="false"
    tools:listitem="@layout/item_pet" />

</androidx.constraintlayout.widget.ConstraintLayout>