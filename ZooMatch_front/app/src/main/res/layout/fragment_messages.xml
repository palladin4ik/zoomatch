<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@color/purple_background">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/white"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:elevation="4dp">

    <ImageView
      android:id="@+id/iv_back"
      android:layout_width="28dp"
      android:layout_height="28dp"
      android:src="@drawable/ic_arrow_back"
      app:tint="@color/purple_primary"
      android:layout_marginEnd="12dp"
      android:background="?attr/selectableItemBackgroundBorderless" />

    <ImageView
      android:id="@+id/iv_user_avatar"
      android:layout_width="40dp"
      android:layout_height="40dp"
      android:scaleType="centerCrop"
      android:src="@drawable/test_avatar"
      android:layout_marginEnd="10dp" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/tv_user_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        tools:text="Анна Смирнова" />

      <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/gray"
        tools:text="В сети" />
    </LinearLayout>
  </LinearLayout>

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="#E0E0E0" />

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/rv_messages"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:clipToPadding="false"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp"
    android:background="@color/purple_background" />

  <LinearLayout
    android:id="@+id/editing_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp"
    android:background="@color/purple_light"
    android:visibility="gone">

    <TextView
      android:id="@+id/tv_editing_label"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Редактирование"
      android:textSize="13sp"
      android:textStyle="bold"
      android:textColor="@color/purple_primary"
      android:drawableStart="@drawable/ic_edit_pencil"
      android:drawablePadding="6dp" />

    <ImageView
      android:id="@+id/btn_cancel_edit"
      android:layout_width="24dp"
      android:layout_height="24dp"
      android:src="@drawable/ic_close_gray"
      android:background="?attr/selectableItemBackgroundBorderless"
      android:contentDescription="Отмена" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp"
    android:background="@color/white"
    android:elevation="8dp">

    <ImageButton
      android:id="@+id/btn_attachment"
      android:layout_width="42dp"
      android:layout_height="42dp"
      android:src="@drawable/ic_add"
      android:background="?attr/selectableItemBackgroundBorderless"
      app:tint="@color/purple_primary"
      android:contentDescription="Прикрепить" />

    <com.google.android.material.card.MaterialCardView
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_marginHorizontal="8dp"
      app:cardCornerRadius="24dp"
      app:cardElevation="0dp"
      app:strokeWidth="1dp"
      app:strokeColor="#E0E0E0"
      app:cardBackgroundColor="@color/white">

      <EditText
        android:id="@+id/et_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:hint="Сообщение..."
        android:textSize="15sp"
        android:textColor="@color/black"
        android:textColorHint="@color/gray"
        android:maxLines="4"
        android:background="@null"
        android:inputType="textMultiLine" />
    </com.google.android.material.card.MaterialCardView>

    <ImageButton
      android:id="@+id/btn_send"
      android:layout_width="42dp"
      android:layout_height="42dp"
      android:src="@drawable/ic_send"
      android:background="@drawable/bg_send_button"
      app:tint="@android:color/white"
      android:contentDescription="Отправить" />
  </LinearLayout>
</LinearLayout>
