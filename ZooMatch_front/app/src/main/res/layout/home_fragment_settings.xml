<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp"
    tools:context=".ui.homeScreen.settings.SettingsFragment">

  <TextView
      android:id="@+id/appSettingsText"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="16dp"
      android:layout_marginTop="16dp"
      android:text="@string/app_settings"
      android:textAppearance="?attr/textAppearanceHeadlineSmall"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent" />

  <com.google.android.material.card.MaterialCardView
      android:id="@+id/appSettingsCard"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintTop_toBottomOf="@id/appSettingsText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ic_push"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/notification_svgrepo_com" />

        <TextView
            android:id="@+id/pushNotificationsText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/enable_push_notifications" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ic_email"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/email_svgrepo_com" />

        <TextView
            android:id="@+id/emailNotificationsText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/enable_email_notifications" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ic_privacy"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/policy_svgrepo_com" />

        <TextView
            android:id="@+id/privacyPolicy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/privacy_policy" />

        <ImageView
            android:id="@+id/ic_chevron_right_1"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:src="@android:drawable/ic_menu_edit" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ic_terms"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/policy_svgrepo_com" />

        <TextView
            android:id="@+id/termsOfUse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/terms_of_use" />

        <ImageView
            android:id="@+id/ic_chevron_right_2"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:src="@android:drawable/ic_menu_edit" />
      </LinearLayout>
    </LinearLayout>
  </com.google.android.material.card.MaterialCardView>

  <TextView
      android:id="@+id/accSettingsText"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="24dp"
      android:text="@string/account_settings"
      android:textAppearance="?attr/textAppearanceHeadlineSmall"
      app:layout_constraintTop_toBottomOf="@id/appSettingsCard"
      app:layout_constraintStart_toStartOf="parent" />

  <com.google.android.material.card.MaterialCardView
      android:id="@+id/accSettingsCard"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      app:layout_constraintTop_toBottomOf="@id/accSettingsText"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ic_approve"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/approve_svgrepo_com" />

        <TextView
            android:id="@+id/approveProfileText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/approve_profile" />

        <ImageView
            android:id="@+id/ic_chevron_right_3"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:src="@android:drawable/ic_menu_edit" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ic_editPass"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/password_svgrepo_com" />

        <TextView
            android:id="@+id/editPasswordText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/edit_password" />

        <ImageView
            android:id="@+id/ic_chevron_right_4"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:src="@android:drawable/ic_menu_edit" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ic_logout"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/logout_svgrepo_com" />

        <TextView
            android:id="@+id/logOutText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/logout" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/ic_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/delete_svgrepo_com" />

        <TextView
            android:id="@+id/deleteAccountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/delete_account" />
      </LinearLayout>
    </LinearLayout>
  </com.google.android.material.card.MaterialCardView>

  <TextView
      android:id="@+id/appVersionText"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="24dp"
      android:text="Version: 0.0.1"
      android:textAppearance="?attr/textAppearanceBodySmall"
      app:layout_constraintTop_toBottomOf="@id/accSettingsCard"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
